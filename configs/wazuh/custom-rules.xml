<!-- Wazuh Custom Rules — SOC Tier 1 ESAIP -->
<group name="custom_soc,">

  <!-- Brute Force SSH -->
  <rule id="100001" level="10" frequency="5" timeframe="60">
    <if_matched_sid>5716</if_matched_sid>
    <description>SSH Brute Force: Multiple failed logins from same source</description>
    <mitre>
      <id>T1110</id>
    </mitre>
    <group>authentication_failures,pci_dss_10.2.4,pci_dss_10.2.5,</group>
  </rule>

  <!-- Privilege Escalation sudo -->
  <rule id="100002" level="12">
    <if_sid>5402</if_sid>
    <match>sudo</match>
    <regex>command not allowed</regex>
    <description>Privilege Escalation attempt via sudo</description>
    <mitre>
      <id>T1548.003</id>
    </mitre>
  </rule>

  <!-- Suspicious process creation Windows -->
  <rule id="100003" level="14">
    <if_sid>61603</if_sid>
    <field name="win.eventdata.parentImage" type="pcre2">(?i)(cmd\.exe|powershell\.exe)</field>
    <field name="win.eventdata.image" type="pcre2">(?i)(mimikatz|meterpreter|cobalt)</field>
    <description>Malicious tool execution detected</description>
    <mitre>
      <id>T1059.001</id>
    </mitre>
  </rule>

  <!-- Lateral Movement - Pass the Hash -->
  <rule id="100004" level="13">
    <if_sid>60106</if_sid>
    <field name="win.eventdata.logonType">3</field>
    <field name="win.eventdata.authenticationPackageName">NTLM</field>
    <description>Possible Pass-the-Hash attack detected</description>
    <mitre>
      <id>T1550.002</id>
    </mitre>
  </rule>

  <!-- Persistence - Registry Autorun -->
  <rule id="100005" level="11">
    <if_sid>61612</if_sid>
    <field name="win.eventdata.targetObject" type="pcre2">(?i)(currentversion\\run)</field>
    <description>Persistence via Registry Run key</description>
    <mitre>
      <id>T1547.001</id>
    </mitre>
  </rule>

</group>